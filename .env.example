# 本文件集中管理本地运行参数。修改后请重启相关服务使配置生效。
# 敏感信息只应保存在 .env；.env.example 仅保留安全示例或空值。

# =============================================================================
# 应用基础与安全
# 服务名称、运行环境、签名密钥和登录令牌有效期。
# =============================================================================
# APP_NAME：应用显示名称。
APP_NAME=小红书本地活动信息抓取系统

# APP_ENV：运行环境标识，例如 development、test 或 production。
APP_ENV=development

# SECRET_KEY：JWT 等安全功能使用的签名密钥；生产环境必须使用随机强密钥。
SECRET_KEY=replace-with-a-random-local-secret

# JWT_EXPIRE_HOURS：登录令牌有效时长，单位：小时。
JWT_EXPIRE_HOURS=24

# =============================================================================
# 管理员账号
# 本地系统初始管理员登录信息。
# =============================================================================
# ADMIN_USERNAME：管理员登录用户名。
ADMIN_USERNAME=admin

# ADMIN_PASSWORD：管理员登录密码；请勿提交真实密码到 Git。
ADMIN_PASSWORD=Admin@123

# =============================================================================
# 后端 API 与跨域
# FastAPI 地址、端口、路由前缀以及允许访问的前端来源。
# =============================================================================
# API_V1_PREFIX：后端 API 的统一路由前缀。
API_V1_PREFIX=/api/v1

# API_HOST：后端监听地址；127.0.0.1 表示仅本机可访问。
API_HOST=127.0.0.1

# API_PORT：后端监听端口。
API_PORT=8000

# CORS_ORIGINS：允许跨域访问 API 的前端地址，多个地址用英文逗号分隔。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# 前端开发服务
# Vue/Vite 本地服务及前端请求 API 的参数。
# =============================================================================
# WEB_HOST：前端开发服务器监听地址。
WEB_HOST=127.0.0.1

# WEB_PORT：前端开发服务器监听端口。
WEB_PORT=5173

# VITE_API_BASE_URL：浏览器请求后端时使用的 API 基础路径。
VITE_API_BASE_URL=/api/v1

# VITE_API_TIMEOUT_MS：前端 API 请求超时时间，单位：毫秒。
VITE_API_TIMEOUT_MS=10000

# =============================================================================
# 数据库与本地文件
# SQLite、图片、导出文件、归档、备份及模型文件的保存位置。
# =============================================================================
# DATABASE_URL：数据库连接地址；一期使用本地 SQLite 文件。
DATABASE_URL=sqlite:///./data/app.db

# DATA_DIR：运行数据根目录。
DATA_DIR=./data

# IMAGE_DIR：抓取图片的默认保存目录。
IMAGE_DIR=./data/images

# EXPORT_DIR：Excel 和 Markdown 等导出文件的保存目录。
EXPORT_DIR=./data/exports

# ARCHIVE_DIR：按日期归档的图片与 Markdown 保存目录。
ARCHIVE_DIR=./data/archive

# BACKUP_DIR：数据库及运行数据备份目录。
BACKUP_DIR=./data/backups

# PADDLEOCR_MODEL_DIR：PaddleOCR 模型文件保存目录。
PADDLEOCR_MODEL_DIR=./data/models/paddleocr

# =============================================================================
# 活动日期校验
# 控制活动发生时间的有效范围，与小红书笔记发布时间筛选无关。
# =============================================================================
# ACTIVITY_FUTURE_WINDOW_DAYS：从任务首次开始日算起，最多保留未来多少天的活动。
ACTIVITY_FUTURE_WINDOW_DAYS=60

# =============================================================================
# Celery 任务队列
# 一期使用本地 filesystem broker，无需 Redis。
# =============================================================================
# CELERY_BROKER_URL：Celery 消息代理地址；filesystem:// 表示使用本地文件队列。
CELERY_BROKER_URL=filesystem://

# CELERY_FOLDER：Celery 本地消息队列目录。
CELERY_FOLDER=./data/celery

# CELERY_TIMEZONE：Celery 定时任务使用的时区。
CELERY_TIMEZONE=Asia/Shanghai

# CELERY_WORKER_POOL：Worker 执行池；本地兼容模式使用 solo。
CELERY_WORKER_POOL=solo

# CELERY_WORKER_CONCURRENCY：单个 Worker 的并发任务数。
CELERY_WORKER_CONCURRENCY=1

# CELERY_LOG_LEVEL：Celery 日志级别，例如 INFO 或 DEBUG。
CELERY_LOG_LEVEL=INFO

# =============================================================================
# 定时任务与抓取批次
# 每周任务执行时间、抓取间隔和每批数据量。
# =============================================================================
# WEEKLY_CRAWL_DAY_OF_WEEK：每周抓取执行日；Celery crontab 中 0 表示周日、1 表示周一。
WEEKLY_CRAWL_DAY_OF_WEEK=1

# WEEKLY_CRAWL_HOUR：每周抓取执行小时，使用 24 小时制。
WEEKLY_CRAWL_HOUR=2

# WEEKLY_CRAWL_MINUTE：每周抓取执行分钟。
WEEKLY_CRAWL_MINUTE=0

# SEARCH_INTERVAL_MIN：连续搜索操作的最小随机等待时间，单位：秒。
SEARCH_INTERVAL_MIN=10

# SEARCH_INTERVAL_MAX：连续搜索操作的最大随机等待时间，单位：秒。
SEARCH_INTERVAL_MAX=15

# SEARCH_LIMIT：普通单次搜索最多处理的笔记数量。
SEARCH_LIMIT=50

# WEEKLY_SEARCH_LIMIT：每周全量抓取最多处理的笔记数量。
WEEKLY_SEARCH_LIMIT=500

# =============================================================================
# 小红书浏览器与滚动策略
# 连接已登录浏览器，并控制搜索页及详情页的下拉次数。
# =============================================================================
# OPENCLI_CDP_ENDPOINT：已登录浏览器的 Chrome DevTools Protocol 地址。
OPENCLI_CDP_ENDPOINT=http://localhost:9222

# OPENCLI_BROWSER_COMMAND_TIMEOUT：opencli 单条浏览器命令超时时间，单位：秒；超过该时间会返回 exitCode 75。
OPENCLI_BROWSER_COMMAND_TIMEOUT=120

# XHS_LOGIN_URL：等待登录任务打开的固定小红书页面。
XHS_LOGIN_URL=https://www.xiaohongshu.com/explore

# XHS_LOGIN_BROWSER：本地登录时唤醒的浏览器名称；OpenCLI 复用该 Chrome 登录态。
XHS_LOGIN_BROWSER=Google Chrome

# XHS_SEARCH_TARGET_COUNT：搜索页期望收集的笔记数量。
XHS_SEARCH_TARGET_COUNT=50

# XHS_SEARCH_SCROLL_MAX_ROUNDS：搜索结果页最多下拉轮数。
XHS_SEARCH_SCROLL_MAX_ROUNDS=8

# XHS_DETAIL_SCROLL_MAX_ROUNDS：单篇笔记详情页最多下拉轮数。
XHS_DETAIL_SCROLL_MAX_ROUNDS=8

# XHS_SCROLL_PIXELS：每次页面下拉的像素数。
XHS_SCROLL_PIXELS=800

# XHS_SCROLL_STAGNANT_ROUNDS：连续多少轮没有新内容后停止下拉。
XHS_SCROLL_STAGNANT_ROUNDS=2

# =============================================================================
# 单笔记流水线重试
# 详情、下载、OCR 和模型提取的最大尝试次数与重试间隔。
# =============================================================================
# PIPELINE_STAGE_MAX_RETRIES：每个处理阶段最多尝试次数，包含第一次执行。
PIPELINE_STAGE_MAX_RETRIES=2

# PIPELINE_STAGE_RETRY_DELAY_SECONDS：阶段失败后的等待时间，单位：秒。
PIPELINE_STAGE_RETRY_DELAY_SECONDS=2

# =============================================================================
# MiniMax 活动识别模型
# 用于从笔记文字和图片识别结构化活动信息。
# =============================================================================
# MINIMAX_API_KEY：MiniMax API 密钥；只写入本地 .env，不要提交到 Git。
MINIMAX_API_KEY=

# MINIMAX_BASE_URL：MiniMax API 服务基础地址。
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# MINIMAX_MODEL：活动识别使用的模型名称。
MINIMAX_MODEL=MiniMax-M3

# MINIMAX_CHAT_PATH：MiniMax 文本对话接口路径。
MINIMAX_CHAT_PATH=/text/chatcompletion_v2

# MINIMAX_TIMEOUT_SECONDS：单次 MiniMax API 请求超时时间，单位：秒。
MINIMAX_TIMEOUT_SECONDS=180

# =============================================================================
# PaddleOCR
# 本地图片文字识别开关、语言及图像预处理参数。
# =============================================================================
# OCR_ENABLED：是否启用 PaddleOCR；true 启用，false 关闭。
OCR_ENABLED=false

# OCR_LANGUAGE：OCR 识别语言；ch 表示中英文。
OCR_LANGUAGE=ch

# OCR_MIN_CONFIDENCE：OCR 文本最低置信度，范围 0 到 1。
OCR_MIN_CONFIDENCE=0.5

# OCR_USE_DOC_ORIENTATION_CLASSIFY：是否启用文档方向分类。
OCR_USE_DOC_ORIENTATION_CLASSIFY=false

# OCR_USE_DOC_UNWARPING：是否启用文档图像矫正。
OCR_USE_DOC_UNWARPING=false

# OCR_USE_TEXTLINE_ORIENTATION：是否启用文本行方向分类。
OCR_USE_TEXTLINE_ORIENTATION=false
